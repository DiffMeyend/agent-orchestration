{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/main/packages/nx/schemas/project-schema.json",
  "name": "agents",
  "projectType": "library",
  "root": "tools/agents",
  "sourceRoot": "tools/agents",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/lint_agents.mjs"
      }
    },
    "check:ids": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/check_agent_ids.mjs"
      }
    },
    "guard:archive": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/check_no_archive_refs.mjs"
      }
    }
  }
}
