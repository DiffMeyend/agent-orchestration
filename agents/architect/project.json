{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/main/packages/nx/schemas/project-schema.json",
  "name": "agents-architect",
  "projectType": "library",
  "root": "agents/architect",
  "sourceRoot": "agents/architect/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p agents/architect/tsconfig.lib.json && tsc-alias -p agents/architect/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ESLINT_USE_FLAT_CONFIG=false eslint agents/architect/src --ext .ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run agents/architect --passWithNoTests"
      }
    }
  },
  "tags": ["scope:agent", "type:lib"]
}
