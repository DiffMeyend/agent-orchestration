{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/main/packages/nx/schemas/project-schema.json",
  "name": "agents-polymath",
  "projectType": "library",
  "root": "agents/polymath",
  "sourceRoot": "agents/polymath/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p agents/polymath/tsconfig.lib.json && tsc-alias -p agents/polymath/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ESLINT_USE_FLAT_CONFIG=false eslint agents/polymath/src --ext .ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run agents/polymath --passWithNoTests"
      }
    }
  },
  "tags": ["scope:agent", "type:lib"]
}
