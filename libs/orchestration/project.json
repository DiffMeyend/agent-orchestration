{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/main/packages/nx/schemas/project-schema.json",
  "name": "libs-orchestration",
  "projectType": "library",
  "root": "libs/orchestration",
  "sourceRoot": "libs/orchestration/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/orchestration/tsconfig.lib.json && tsc-alias -p libs/orchestration/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ESLINT_USE_FLAT_CONFIG=false eslint libs/orchestration/src --ext .ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run libs/orchestration --passWithNoTests"
      }
    }
  },
  "tags": ["scope:lib", "type:lib"]
}
